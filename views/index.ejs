<%
  const featuredEvent = model.featuredEvent;
  const ctaHref = featuredEvent?.googleFormUrl || "";
  const ctaLabel = featuredEvent?.cta.label || "신청 오픈 예정";
  const canApply = Boolean(ctaHref);
  const headerTitle = model.content.hero.headerTitle || "클래식을 좋아하세요..?";
  const nextCtaLabel = model.content.hero.nextCtaLabel || "다음기수 신청하기";
  const participants = model.content.participants;
  const displayParticipants = participants.length && !participants.includes("공무원") ? [...participants, "공무원"] : participants;
  const heroSubtitle = model.content.hero.subheadline || "";
  const heroSubtitleLines = (heroSubtitle.replace(/\s+/g, " ").match(/[^.!?。！？]+[.!?。！？]+/g) || [heroSubtitle])
    .map((line) => line.trim())
    .filter(Boolean);
  const heroImages = [
    "/assets/images/classic-salon-hero.jpg",
    "/assets/images/rotation-conversation.jpg",
    "/assets/images/classic-detail.jpg"
  ];
  const previousStatusImages = [
    { label: "1기", src: "/assets/images/participant-status-1st.jpg" },
    { label: "2기", src: "/assets/images/participant-status-2nd.jpg" },
    { label: "3기", src: "/assets/images/participant-status-3rd.jpg" },
    { label: "4기", src: "/assets/images/participant-status-4th.jpg" },
    { label: "5기", src: "/assets/images/participant-status-5th.jpg" }
  ];
  const footerTitle = model.content.legal.footerTitle || "클래식을 좋아하세요..?";
  const footerDescription = model.content.legal.footerDescription || "서울 강남권에서 열리는 국내 최초 클래식 취향 기반 로테이션 소개팅";
  const chatbotQuickReplies = ["신청 방법", "일정", "장소", "참가비", "개인정보"];
  const chatbotData = {
    applyUrl: ctaHref,
    applyLabel: ctaLabel,
    instagramUrl: model.content.instagram.url || "",
    faq: model.content.faq || [],
    event: featuredEvent
      ? {
          title: featuredEvent.publicTitle,
          generationLabel: featuredEvent.generationLabel,
          eventDate: featuredEvent.eventDate,
          region: featuredEvent.region,
          venueNote: featuredEvent.venueNote,
          capacityNote: featuredEvent.capacityNote,
          applicationConditions: featuredEvent.applicationConditions,
          timeSlots: featuredEvent.timeSlots.map((slot) => `${slot.label} ${slot.startsAt}-${slot.endsAt}`),
          priceRows: featuredEvent.priceRows.map((price) => `${price.label} ${price.amount}${price.note ? ` (${price.note})` : ""}`)
        }
      : null
  };
  const chatbotJson = JSON.stringify(chatbotData)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026");
  const reelPreviewImages = [
    "/assets/images/classic-salon-hero.jpg",
    "/assets/images/rotation-conversation.jpg",
    "/assets/images/classic-detail.jpg",
    "/assets/images/classic-salon-hero.jpg"
  ];
  const reelPreviewCaptions = [
    "처음 만나는 클래식 살롱의 공기",
    "짧지만 깊게 이어지는 로테이션 대화",
    "공연과 음악 취향으로 가까워지는 순간",
    "서울 강남권에서 열리는 다음 만남"
  ];
%>

<header class="site-header">
  <a class="wordmark" href="#top" aria-label="<%= headerTitle %> 홈">
    <img class="wordmark-image" src="/assets/images/doyoulikeclassic-wordmark-gold.png" alt="<%= headerTitle %>">
  </a>
  <div class="header-menu-card">
    <nav class="nav-links" aria-label="주요 섹션">
      <a href="#event">일정</a>
      <a href="#application-status">이전 기수</a>
      <a href="#process">절차</a>
      <a href="#instagram">현장 영상</a>
      <a href="#faq">FAQ</a>
      <a href="#chatbot" data-chatbot-open>문의</a>
    </nav>
  </div>
  <div class="header-cta">
    <% if (canApply) { %>
      <a class="button button-primary button-card-radius" href="<%= ctaHref %>" target="_blank" rel="noreferrer"><%= ctaLabel %></a>
    <% } else { %>
      <span class="button button-disabled button-card-radius" aria-disabled="true"><%= ctaLabel %></span>
    <% } %>
  </div>
</header>

<main id="top">
  <section class="hero section" aria-labelledby="hero-title">
    <div class="shape shape-lemon" aria-hidden="true"></div>
    <div class="section-inner hero-grid">
      <div class="hero-copy reveal">
        <p class="eyebrow hero-eyebrow"><%= model.content.hero.eyebrow || "국내 최초 클래식 로테이션 소개팅" %></p>
        <h1 id="hero-title"><%= model.content.hero.headline %></h1>
        <p class="hero-subtitle">
          <% heroSubtitleLines.forEach((line) => { %>
            <span><%= line %></span>
          <% }) %>
        </p>
        <div class="badge-row" aria-label="주요 특징">
          <% model.content.hero.badges.forEach((badge) => { %>
            <span class="badge"><%= badge %></span>
          <% }) %>
        </div>
      </div>
      <div class="hero-media-grid reveal" aria-label="클래식 살롱 분위기 이미지">
        <% heroImages.forEach((image, index) => { %>
          <img src="<%= image %>" alt="클래식 살롱 분위기 <%= index + 1 %>">
        <% }) %>
      </div>
    </div>
  </section>

  <% if (featuredEvent) { %>
    <section id="event" class="section event-band" aria-labelledby="event-title">
      <div class="section-inner event-grid">
        <div class="event-summary reveal">
          <p class="eyebrow section-eyebrow">Current Event</p>
          <h2 id="event-title"><%= featuredEvent.generationLabel %></h2>
          <div class="event-application-group">
            <dl class="event-facts">
              <div><dt>날짜</dt><dd><%= featuredEvent.eventDate %></dd></div>
              <div><dt>장소</dt><dd><%= featuredEvent.venueNote %></dd></div>
              <div><dt>정원</dt><dd><%= featuredEvent.capacityNote %></dd></div>
              <div><dt>조건</dt><dd><%= featuredEvent.applicationConditions %></dd></div>
            </dl>
            <div class="hero-actions event-actions">
              <% if (canApply) { %>
                <a class="button button-primary button-card-radius" href="<%= ctaHref %>" target="_blank" rel="noreferrer"><%= ctaLabel %></a>
              <% } else { %>
                <span class="button button-disabled button-card-radius" aria-disabled="true"><%= ctaLabel %></span>
              <% } %>
              <span class="button button-white button-card-radius event-next-button" aria-disabled="true"><%= nextCtaLabel %></span>
            </div>
          </div>
        </div>
        <div class="event-details reveal" aria-label="시간과 참가비">
          <section class="detail-block">
            <h3>시간</h3>
            <ul class="slot-list">
              <% featuredEvent.timeSlots.forEach((slot) => { %>
                <li><span><%= slot.label %></span><strong><%= slot.startsAt %>-<%= slot.endsAt %></strong></li>
              <% }) %>
            </ul>
          </section>
          <section class="detail-block">
            <h3>참가비</h3>
            <div class="price-grid">
              <% featuredEvent.priceRows.forEach((price) => { %>
                <div class="price-row">
                  <span><%= price.label %></span>
                  <strong><%= price.amount %></strong>
                  <% if (price.note) { %><small><%= price.note %></small><% } %>
                </div>
              <% }) %>
            </div>
          </section>
          <p class="notice event-payment-notice">참여 확정되신 분들께 별도로 결제 안내드립니다.</p>
        </div>
      </div>
    </section>
  <% } %>

  <section id="application-status" class="section application-status-section" aria-labelledby="application-status-title">
    <div class="section-inner application-status-layout">
      <div class="section-heading application-status-heading reveal">
        <p class="eyebrow section-eyebrow">Live Status</p>
        <h2 id="application-status-title">이전 기수 참가자 데이터</h2>
      </div>
      <div class="status-carousel reveal" aria-label="이전 기수 참가자 데이터 이미지" data-status-carousel>
        <button class="status-carousel-button status-carousel-button-prev" type="button" aria-label="이전 참가자 데이터 보기" data-status-carousel-prev>‹</button>
        <div class="status-carousel-track" tabindex="0" data-status-carousel-track>
          <% previousStatusImages.forEach((image) => { %>
            <article class="status-board-image-card" aria-label="<%= image.label %> 참여자 현황 이미지">
              <img class="status-board-image" src="<%= image.src %>" alt="클래식을 좋아하세요 <%= image.label %> 참여자 현황" loading="lazy">
              <span class="status-generation-label"><%= image.label %></span>
            </article>
          <% }) %>
        </div>
        <button class="status-carousel-button status-carousel-button-next" type="button" aria-label="다음 참가자 데이터 보기" data-status-carousel-next>›</button>
      </div>
    </div>
  </section>

  <section id="why-classic" class="section why-section" aria-labelledby="why-title">
    <div class="section-inner split-grid">
      <div class="image-stack reveal">
        <img src="/assets/images/rotation-conversation.jpg" alt="클래식 음악을 주제로 대화하는 테이블 분위기">
      </div>
      <div class="reveal">
        <div class="section-heading">
          <p class="eyebrow section-eyebrow">Why Classic</p>
          <h2 id="why-title">첫 만남의 어색함,<br>클래식이 해결해줄 거예요.</h2>
        </div>
        <div class="reason-list">
          <article>
            <h3><span>01</span><strong>연주로 여는 오프닝</strong></h3>
            <p>본격적인 대화 전, 참가자분들이 직접 준비한 짧은 연주를 감상합니다.<br>서로의 연주를 듣다 보면 첫 만남의 긴장도 기분 좋은 설렘으로 바뀔 거예요.</p>
          </article>
          <article>
            <h3><span>02</span><strong>취향으로 여는 대화</strong></h3>
            <p>좋아하는 공연과 연주자 이야기로 자연스럽게 대화를 시작해 보세요.</p>
          </article>
          <article>
            <h3><span>03</span><strong>짧고 깊은 만남</strong></h3>
            <p>여러 사람을 순차적으로 만나며 긴 1:1 데이트의 부담을 줄입니다.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section id="process" class="section process-band" aria-labelledby="process-title">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow section-eyebrow">Process</p>
        <h2 id="process-title">신청부터 만남까지, 이렇게 진행됩니다.</h2>
      </div>
      <ol class="process-list">
        <li><strong>구글폼 신청</strong><p>이름, 나이, 사진 등 인적사항을 제출합니다.</p></li>
        <li><strong>내부 검토</strong><p>성비와 나이대를 조율해 참여자를 선정합니다.</p></li>
        <li><strong>개별 안내</strong><p>선정자에게 참여 확정 문자 및 결제 안내드립니다.</p></li>
        <li><strong>로테이션 소개팅</strong><p>호스트 안내에 따라 순차적으로 1:1 대화를 나눕니다.</p></li>
      </ol>
    </div>
  </section>

  <section class="section participants-section" aria-labelledby="participants-title">
    <div class="section-inner participants-layout">
      <div class="reveal">
        <div class="section-heading">
          <p class="eyebrow section-eyebrow">Participants</p>
          <h2 id="participants-title">각자의 일상은 다르지만,<br>음악을 사랑하는 마음은 같습니다.</h2>
        </div>
        <p class="section-copy">
          <% if (displayParticipants.length) { %>
            <span class="participant-line"><%= displayParticipants.join(", ") %>까지.</span><br>다양한 사람들이 클래식을 좋아하세요..? 에서 클래식을 매개로 인연을 만났습니다.
          <% } else { %>
            다양한 사람들이 클래식을 매개로 인연을 만났습니다.
          <% } %>
        </p>
      </div>
      <div class="participant-cloud reveal" aria-label="참여자 예시">
        <% displayParticipants.forEach((participant, index) => { %>
          <span class="participant-chip chip-<%= index % 9 %>"><%= participant %></span>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="instagram" class="section instagram-section" aria-labelledby="instagram-title">
    <div class="section-inner instagram-shell">
      <div class="instagram-profile reveal">
        <div class="instagram-avatar" aria-hidden="true">
          <img src="/assets/images/doyoulikeclassic-logo.jpg" alt="">
        </div>
        <div class="instagram-profile-copy">
          <div class="section-heading">
            <p class="eyebrow section-eyebrow instagram-eyebrow">Instagram</p>
            <h2 id="instagram-title"><span class="instagram-title-line">인스타그램에서 현장 분위기, 다음 기수 모집 소식을</span><br>빠르게 확인해보세요.</h2>
          </div>
        </div>
        <div class="instagram-profile-action">
          <strong><%= model.content.instagram.handle %></strong>
          <% if (model.content.instagram.url) { %>
            <a class="button button-white button-card-radius" href="<%= model.content.instagram.url %>" target="_blank" rel="noreferrer">Instagram에서 보기</a>
          <% } %>
        </div>
      </div>

      <div class="reel-grid instagram-feed" aria-label="Instagram Reels 미리보기">
        <% model.content.instagram.reels.forEach((url, index) => { %>
          <a class="reel-card reveal" href="<%= url %>" target="_blank" rel="noreferrer" aria-label="Instagram Reel <%= String(index + 1).padStart(2, "0") %> 새 창으로 보기">
            <img src="<%= reelPreviewImages[index % reelPreviewImages.length] %>" alt="<%= reelPreviewCaptions[index % reelPreviewCaptions.length] %>" loading="lazy">
            <span class="reel-shade" aria-hidden="true"></span>
            <span class="reel-badge">REELS</span>
            <span class="reel-play" aria-hidden="true"></span>
            <span class="reel-copy">
              <small><%= model.content.instagram.handle %></small>
              <strong><%= reelPreviewCaptions[index % reelPreviewCaptions.length] %></strong>
            </span>
            <span class="reel-actions" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </span>
          </a>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="faq" class="section faq-section" aria-labelledby="faq-title">
    <div class="section-inner faq-grid">
      <div class="faq-heading reveal">
        <div class="section-heading">
          <p class="eyebrow section-eyebrow">FAQ</p>
          <h2 id="faq-title">자주 묻는 질문</h2>
        </div>
      </div>
      <div class="faq-list">
        <% model.content.faq.forEach((item) => { %>
          <details class="faq-item reveal">
            <summary><%= item.question %></summary>
            <p><%= item.answer %></p>
          </details>
        <% }) %>
      </div>
      <div class="faq-chatbot-inline reveal">
        <div class="faq-chatbot-copy">
          <p class="eyebrow section-eyebrow">Q&amp;A</p>
          <h2 id="contact-title">궁금한 점은 챗봇에게 바로 물어보세요.</h2>
        </div>
        <div class="chatbot-inline-action">
          <button class="button button-primary" type="button" data-chatbot-open>Q&amp;A 챗봇 열기</button>
          <small>답변 내용은 관리자 화면의 FAQ와 행사 정보 수정 내용이 반영됩니다.</small>
        </div>
      </div>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="section-inner footer-grid">
    <div class="footer-brand">
      <img class="footer-logo" src="/assets/images/doyoulikeclassic-logo.jpg" alt="">
      <div>
        <strong><%= footerTitle %></strong>
        <p><%= footerDescription %></p>
      </div>
    </div>
    <dl class="footer-info-grid">
      <div><dt>Instagram</dt><dd><a href="<%= model.content.instagram.url %>" target="_blank" rel="noreferrer"><%= model.content.instagram.handle %></a></dd></div>
      <div>
        <dt>Contact</dt>
        <dd>
          <a href="#chatbot" data-chatbot-open><%= model.content.legal.contact || "Q&A 챗봇" %></a>
        </dd>
      </div>
    </dl>
  </div>
</footer>

<script type="application/json" id="chatbot-data"><%- chatbotJson %></script>

<div id="chatbot" class="chatbot-widget" data-chatbot-widget>
  <button class="chatbot-launcher" type="button" data-chatbot-toggle aria-expanded="false" aria-controls="chatbot-panel">
    <span>Q&amp;A</span>
    <strong>챗봇</strong>
  </button>
  <section id="chatbot-panel" class="chatbot-window" aria-label="Q&A 챗봇" hidden>
    <header class="chatbot-header">
      <div>
        <strong>Q&amp;A 챗봇</strong>
        <small>FAQ와 현재 행사 정보 기준</small>
      </div>
      <button type="button" data-chatbot-close>닫기</button>
    </header>
    <div class="chatbot-messages" data-chatbot-messages aria-live="polite"></div>
    <div class="chatbot-quick-replies" aria-label="빠른 질문">
      <% chatbotQuickReplies.forEach((reply) => { %>
        <button type="button" data-chatbot-query="<%= reply %>"><%= reply %></button>
      <% }) %>
    </div>
    <form class="chatbot-form" data-chatbot-form>
      <label for="chatbot-input">질문 입력</label>
      <input id="chatbot-input" name="message" placeholder="예: 신청은 어떻게 하나요?" autocomplete="off">
      <button type="submit">보내기</button>
    </form>
  </section>
</div>

<div class="mobile-cta" aria-label="모바일 신청 버튼">
  <% if (canApply) { %>
    <a class="button button-large button-card-radius" href="<%= ctaHref %>" target="_blank" rel="noreferrer"><%= ctaLabel %></a>
  <% } else { %>
    <span class="button button-disabled button-large button-card-radius" aria-disabled="true"><%= ctaLabel %></span>
  <% } %>
</div>
