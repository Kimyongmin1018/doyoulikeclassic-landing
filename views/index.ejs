<%
  const featuredEvent = model.featuredEvent;
  const ctaHref = featuredEvent?.googleFormUrl || "";
  const ctaLabel = featuredEvent?.cta.label || "신청 오픈 예정";
  const canApply = Boolean(ctaHref);
%>

<header class="site-header">
  <a class="wordmark" href="#top" aria-label="클래식을 좋아하세요 홈">클래식을 좋아하세요</a>
  <nav class="nav-links" aria-label="주요 섹션">
    <a href="#event">일정</a>
    <a href="#why-classic">왜 클래식인가요</a>
    <a href="#process">진행 방식</a>
    <a href="#faq">FAQ</a>
  </nav>
  <% if (canApply) { %>
    <a class="button button-primary" href="<%= ctaHref %>" target="_blank" rel="noreferrer"><%= ctaLabel %></a>
  <% } else { %>
    <span class="button button-disabled" aria-disabled="true"><%= ctaLabel %></span>
  <% } %>
</header>

<main id="top">
  <section class="hero section" aria-labelledby="hero-title">
    <div class="shape shape-lemon" aria-hidden="true"></div>
    <div class="shape shape-coral" aria-hidden="true"></div>
    <div class="section-inner hero-grid">
      <div class="hero-copy reveal">
        <p class="eyebrow"><%= model.content.hero.eyebrow || "국내 최초 클래식 로테이션 소개팅" %></p>
        <h1 id="hero-title"><%= model.content.hero.headline %></h1>
        <p class="hero-subtitle"><%= model.content.hero.subheadline %></p>
        <div class="badge-row" aria-label="주요 특징">
          <% model.content.hero.badges.forEach((badge) => { %>
            <span class="badge"><%= badge %></span>
          <% }) %>
        </div>
        <div class="hero-actions">
          <% if (canApply) { %>
            <a class="button button-large" href="<%= ctaHref %>" target="_blank" rel="noreferrer"><%= ctaLabel %></a>
          <% } else { %>
            <span class="button button-disabled button-large" aria-disabled="true"><%= ctaLabel %></span>
          <% } %>
          <a class="text-link" href="#process">진행 방식 보기</a>
        </div>
      </div>
      <figure class="hero-media reveal">
        <img src="/assets/images/classic-salon-hero.jpg" alt="클래식 살롱 분위기의 테이블과 악기">
        <figcaption>5-10명의 이성과 순차적으로 대화하는 로테이션 방식</figcaption>
      </figure>
    </div>
  </section>

  <% if (featuredEvent) { %>
    <section id="event" class="section event-band" aria-labelledby="event-title">
      <div class="section-inner event-grid">
        <div class="event-summary reveal">
          <p class="eyebrow">Current Event</p>
          <h2 id="event-title"><%= featuredEvent.generationLabel %></h2>
          <p class="section-copy"><%= featuredEvent.publicTitle %>는 <%= featuredEvent.region %>에서 열립니다. 참여 확정자에게 장소와 결제 안내를 개별로 전달합니다.</p>
          <dl class="event-facts">
            <div><dt>날짜</dt><dd><%= featuredEvent.eventDate %></dd></div>
            <div><dt>장소</dt><dd><%= featuredEvent.venueNote %></dd></div>
            <div><dt>정원</dt><dd><%= featuredEvent.capacityNote %></dd></div>
            <div><dt>조건</dt><dd><%= featuredEvent.applicationConditions %></dd></div>
          </dl>
          <div class="hero-actions">
            <% if (canApply) { %>
              <a class="button button-primary" href="<%= ctaHref %>" target="_blank" rel="noreferrer"><%= ctaLabel %></a>
            <% } else { %>
              <span class="button button-disabled" aria-disabled="true"><%= ctaLabel %></span>
            <% } %>
            <span class="status-pill"><%= featuredEvent.cta.label %></span>
          </div>
        </div>
        <div class="event-details reveal" aria-label="시간과 참가비">
          <section class="detail-block">
            <h3>시간</h3>
            <ul class="slot-list">
              <% featuredEvent.timeSlots.forEach((slot) => { %>
                <li><span><%= slot.label %></span><strong><%= slot.startsAt %>-<%= slot.endsAt %></strong></li>
              <% }) %>
            </ul>
          </section>
          <section class="detail-block">
            <h3>참가비</h3>
            <div class="price-grid">
              <% featuredEvent.priceRows.forEach((price) => { %>
                <div class="price-row">
                  <span><%= price.label %></span>
                  <strong><%= price.amount %></strong>
                  <% if (price.note) { %><small><%= price.note %></small><% } %>
                </div>
              <% }) %>
            </div>
            <p class="notice">참여 확정 후 운영자가 결제 안내를 별도로 드립니다.</p>
          </section>
        </div>
      </div>
    </section>
  <% } %>

  <section id="why-classic" class="section why-section" aria-labelledby="why-title">
    <div class="section-inner split-grid">
      <div class="image-stack reveal">
        <img src="/assets/images/rotation-conversation.jpg" alt="클래식 음악을 주제로 대화하는 테이블 분위기">
        <img src="/assets/images/classic-detail.jpg" alt="악보와 현악기 디테일">
      </div>
      <div class="reveal">
        <p class="eyebrow">Why Classic</p>
        <h2 id="why-title">처음 만나는 대화에도 이미 공통의 주제가 있습니다.</h2>
        <div class="reason-list">
          <article>
            <span>01</span>
            <h3>취향에서 시작</h3>
            <p>좋아하는 공연, 악장, 연주자 이야기가 어색함을 부드럽게 풀어줍니다.</p>
          </article>
          <article>
            <span>02</span>
            <h3>짧고 깊은 만남</h3>
            <p>여러 사람을 순차적으로 만나며 긴 1:1 데이트의 부담을 줄입니다.</p>
          </article>
          <article>
            <span>03</span>
            <h3>차분한 진행</h3>
            <p>운영자의 안내에 따라 자리와 순서를 이동해 편안한 분위기를 유지합니다.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section id="process" class="section process-band" aria-labelledby="process-title">
    <div class="section-inner">
      <p class="eyebrow">Process</p>
      <h2 id="process-title">신청부터 만남까지, 이렇게 진행됩니다.</h2>
      <ol class="process-list">
        <li><strong>구글폼 신청</strong><p>가능한 시간대를 모두 선택해 제출합니다.</p></li>
        <li><strong>내부 검토</strong><p>성비와 나이대를 조율해 참여자를 선정합니다.</p></li>
        <li><strong>개별 안내</strong><p>선정자에게 장소와 결제 안내를 따로 전달합니다.</p></li>
        <li><strong>현장 참여</strong><p>호스트 안내에 따라 순차적으로 1:1 대화를 나눕니다.</p></li>
        <li><strong>로테이션</strong><p>짧은 대화 후 다음 자리로 이동하며 여러 사람을 만납니다.</p></li>
        <li><strong>후속 확인</strong><p>운영자의 현재 프로세스에 따라 선호도나 후속 정보를 제출합니다.</p></li>
      </ol>
    </div>
  </section>

  <section class="section participants-section" aria-labelledby="participants-title">
    <div class="section-inner participants-grid">
      <div class="reveal">
        <p class="eyebrow">Participants</p>
        <h2 id="participants-title">각자의 일상은 다르지만, 음악을 사랑하는 마음은 같습니다.</h2>
        <p class="section-copy">클래식 전공자부터 개발자, 교사, 연구원, 금융권 종사자까지 다양한 사람들이 공연과 음악 이야기를 매개로 만났습니다.</p>
      </div>
      <div class="participant-cloud reveal" aria-label="참여자 예시">
        <% model.content.participants.forEach((participant, index) => { %>
          <span class="participant-chip chip-<%= index % 5 %>"><%= participant %></span>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="section instagram-section" aria-labelledby="instagram-title">
    <div class="section-inner">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow">Media</p>
          <h2 id="instagram-title">현장 분위기는 Instagram에서 확인하세요.</h2>
        </div>
        <% if (model.content.instagram.url) { %>
          <a class="text-link" href="<%= model.content.instagram.url %>" target="_blank" rel="noreferrer"><%= model.content.instagram.handle %></a>
        <% } %>
      </div>
      <div class="reel-grid">
        <% model.content.instagram.reels.forEach((url, index) => { %>
          <a class="reel-card reveal" href="<%= url %>" target="_blank" rel="noreferrer">
            <span>Instagram Reel</span>
            <strong><%= String(index + 1).padStart(2, "0") %></strong>
            <small>새 창으로 보기</small>
          </a>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="faq" class="section faq-section" aria-labelledby="faq-title">
    <div class="section-inner faq-grid">
      <div class="reveal">
        <p class="eyebrow">FAQ</p>
        <h2 id="faq-title">처음 신청하는 분들이 자주 묻는 질문</h2>
        <p class="notice">개인정보는 구글폼에서 수집되며, 이 사이트 데이터베이스에는 신청자 개인정보를 저장하지 않습니다.</p>
      </div>
      <div class="faq-list">
        <% model.content.faq.forEach((item) => { %>
          <details class="faq-item reveal">
            <summary><%= item.question %></summary>
            <p><%= item.answer %></p>
          </details>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="section-inner footer-grid">
    <div>
      <strong>클래식을 좋아하세요</strong>
      <p>서울 강남권에서 열리는 클래식 취향 기반 로테이션 소개팅</p>
    </div>
    <dl>
      <div><dt>Instagram</dt><dd><a href="<%= model.content.instagram.url %>" target="_blank" rel="noreferrer"><%= model.content.instagram.handle %></a></dd></div>
      <div><dt>Domain</dt><dd><%= model.content.legal.domain || "www.doyoulikeclassic.com" %></dd></div>
      <div><dt>Contact</dt><dd><%= model.content.legal.contact || "문의 채널 입력 예정" %></dd></div>
    </dl>
    <dl>
      <div><dt>상호</dt><dd><%= model.content.legal.businessName || "상호명 입력 예정" %></dd></div>
      <div><dt>대표</dt><dd><%= model.content.legal.representative || "대표자 입력 예정" %></dd></div>
      <div><dt>사업자등록번호</dt><dd><%= model.content.legal.registrationNumber || "사업자등록번호 입력 예정" %></dd></div>
    </dl>
    <nav aria-label="정책 링크">
      <a href="#faq">이용약관</a>
      <a href="#faq">개인정보 처리방침</a>
      <a href="#event">환불 및 취소 안내</a>
    </nav>
  </div>
</footer>

<div class="mobile-cta" aria-label="모바일 신청 버튼">
  <% if (canApply) { %>
    <a class="button button-large" href="<%= ctaHref %>" target="_blank" rel="noreferrer"><%= ctaLabel %></a>
  <% } else { %>
    <span class="button button-disabled button-large" aria-disabled="true"><%= ctaLabel %></span>
  <% } %>
</div>
