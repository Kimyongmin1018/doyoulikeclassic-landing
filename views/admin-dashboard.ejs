<main class="admin-page">
  <header class="admin-topbar">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>운영 대시보드</h1>
      <p>신청자 개인정보는 구글폼에서 관리하고, 이 사이트는 행사와 콘텐츠 설정만 저장합니다.</p>
    </div>
    <form method="post" action="/admin/logout">
      <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
      <button class="button button-disabled" type="submit">로그아웃</button>
    </form>
  </header>

  <% if (error) { %>
    <p class="form-error" role="alert"><%= error %></p>
  <% } %>

  <section class="admin-grid" aria-label="행사 관리">
    <article class="admin-card">
      <h2>등록된 일정 편집</h2>
      <% if (events.length) { %>
        <div class="admin-event-stack">
          <% events.forEach((event) => { %>
            <section class="admin-event-editor" aria-labelledby="event-editor-<%= event.id %>">
              <div class="admin-list-item">
                <p>
                  <strong id="event-editor-<%= event.id %>"><%= event.publicTitle %></strong>
                  <span><%= event.eventDate || "날짜 미정" %> · <%= event.status %> · <%= event.isFeatured ? "대표" : "보관" %></span>
                </p>
                <% if (!event.isFeatured) { %>
                  <form method="post" action="/admin/events/<%= event.id %>/feature">
                    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                    <button class="button button-disabled" type="submit">대표 지정</button>
                  </form>
                <% } %>
              </div>

              <form method="post" action="/admin/events/<%= event.id %>" class="admin-form">
                <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

                <label>
                  공개 제목
                  <input name="publicTitle" value="<%= event.publicTitle %>" required maxlength="80">
                </label>
                <label>
                  기수 라벨
                  <input name="generationLabel" value="<%= event.generationLabel %>" required maxlength="40">
                </label>
                <label>
                  날짜
                  <input name="eventDate" value="<%= event.eventDate %>" required maxlength="40">
                </label>
                <label>
                  지역
                  <input name="region" value="<%= event.region %>" required maxlength="40">
                </label>
                <label>
                  장소 안내
                  <input name="venueNote" value="<%= event.venueNote %>" required maxlength="120">
                </label>
                <label>
                  정원
                  <input name="capacityNote" value="<%= event.capacityNote %>" required maxlength="60">
                </label>
                <label class="admin-form-wide">
                  신청 조건
                  <input name="applicationConditions" value="<%= event.applicationConditions %>" required maxlength="120">
                </label>
                <label>
                  모집 상태
                  <select name="status">
                    <% ["open", "closing-soon", "closed", "scheduled", "hidden"].forEach((status) => { %>
                      <option value="<%= status %>" <%= event.status === status ? "selected" : "" %>><%= status %></option>
                    <% }) %>
                  </select>
                </label>
                <label>
                  구글폼 링크
                  <input name="googleFormUrl" value="<%= event.googleFormUrl %>" required inputmode="url">
                </label>
                <label class="admin-form-wide">
                  시간 슬롯
                  <textarea name="timeSlotsText" required><%= event.timeSlotsText %></textarea>
                </label>
                <label class="admin-form-wide">
                  참가비
                  <textarea name="priceRowsText" required><%= event.priceRowsText %></textarea>
                </label>

                <button class="button button-primary admin-form-wide" type="submit">행사 저장</button>
              </form>
            </section>
          <% }) %>
        </div>
      <% } else { %>
        <p class="admin-empty">등록된 일정이 없습니다.</p>
      <% } %>
    </article>

    <article class="admin-card">
      <h2>새 일정 추가</h2>
      <form method="post" action="/admin/events" class="admin-form compact-form" aria-label="새 일정 추가">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
        <label>
          공개 제목
          <input name="publicTitle" placeholder="새 일정 제목" required maxlength="80">
        </label>
        <label>
          기수 라벨
          <input name="generationLabel" placeholder="기수 라벨" required maxlength="40">
        </label>
        <label>
          날짜
          <input name="eventDate" placeholder="날짜" required maxlength="40">
        </label>
        <label>
          지역
          <input name="region" value="서울 강남권" required maxlength="40">
        </label>
        <label>
          장소 안내
          <input name="venueNote" value="참여 확정자 개별 안내" required maxlength="120">
        </label>
        <label>
          정원
          <input name="capacityNote" value="최대 10:10" required maxlength="60">
        </label>
        <label class="admin-form-wide">
          신청 조건
          <input name="applicationConditions" placeholder="신청 조건" required maxlength="120">
        </label>
        <label>
          모집 상태
          <select name="status">
            <option value="scheduled">scheduled</option>
            <option value="open">open</option>
            <option value="closing-soon">closing-soon</option>
            <option value="closed">closed</option>
            <option value="hidden">hidden</option>
          </select>
        </label>
        <label>
          구글폼 링크
          <input name="googleFormUrl" value="https://forms.gle/demo" required inputmode="url">
        </label>
        <label class="admin-form-wide">
          시간 슬롯
          <textarea name="timeSlotsText" required>1회차|16:00|18:00</textarea>
        </label>
        <label class="admin-form-wide">
          참가비
          <textarea name="priceRowsText" required>기본|40,000원|</textarea>
        </label>
        <button class="button button-primary admin-form-wide" type="submit">새 일정 추가</button>
      </form>
    </article>
  </section>

  <section class="admin-card content-editor" aria-labelledby="content-editor-title">
    <h2 id="content-editor-title">홈 콘텐츠 / 법무 정보</h2>
    <form method="post" action="/admin/content" class="admin-form">
      <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

      <label>
        히어로 라벨
        <input name="heroEyebrow" value="<%= adminContent.heroEyebrow %>" required maxlength="80">
      </label>
      <label>
        히어로 제목
        <input name="heroHeadline" value="<%= adminContent.heroHeadline %>" required maxlength="140">
      </label>
      <label class="admin-form-wide">
        히어로 설명
        <textarea name="heroSubheadline" required maxlength="500"><%= adminContent.heroSubheadline %></textarea>
      </label>
      <label>
        히어로 배지
        <textarea name="heroBadgesText" required maxlength="500"><%= adminContent.heroBadgesText %></textarea>
      </label>
      <label>
        참여자 예시
        <textarea name="participantsText" required maxlength="500"><%= adminContent.participantsText %></textarea>
      </label>
      <label>
        인스타그램 URL
        <input name="instagramUrl" value="<%= adminContent.instagramUrl %>" required inputmode="url">
      </label>
      <label>
        인스타그램 핸들
        <input name="instagramHandle" value="<%= adminContent.instagramHandle %>" required maxlength="60">
      </label>
      <label class="admin-form-wide">
        인스타그램 릴스
        <textarea name="instagramReelsText" maxlength="1200"><%= adminContent.instagramReelsText %></textarea>
      </label>
      <label class="admin-form-wide">
        FAQ
        <textarea name="faqText" required maxlength="3000"><%= adminContent.faqText %></textarea>
      </label>
      <label>
        상호명
        <input name="businessName" value="<%= adminContent.businessName %>" required maxlength="80">
      </label>
      <label>
        대표자
        <input name="representative" value="<%= adminContent.representative %>" required maxlength="80">
      </label>
      <label>
        사업자등록번호
        <input name="registrationNumber" value="<%= adminContent.registrationNumber %>" required maxlength="80">
      </label>
      <label>
        문의 채널
        <input name="contact" value="<%= adminContent.contact %>" required maxlength="120">
      </label>
      <label>
        도메인
        <input name="domain" value="<%= adminContent.domain %>" required maxlength="80">
      </label>

      <button class="button button-primary admin-form-wide" type="submit">콘텐츠 저장</button>
    </form>
  </section>
</main>
