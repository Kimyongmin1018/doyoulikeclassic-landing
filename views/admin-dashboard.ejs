<main class="admin-page">
  <header class="admin-topbar">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>운영 대시보드</h1>
      <p>신청자 개인정보는 구글폼에서 관리하고, 이 사이트는 행사와 콘텐츠 설정만 저장합니다.</p>
    </div>
    <form method="post" action="/admin/logout">
      <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
      <button class="button button-disabled" type="submit">로그아웃</button>
    </form>
  </header>

  <% if (error) { %>
    <p class="form-error" role="alert"><%= error %></p>
  <% } %>

  <section class="admin-grid" aria-label="행사 관리">
    <article class="admin-card">
      <h2>등록된 일정 편집</h2>
      <% if (events.length) { %>
        <div class="admin-event-stack">
          <% events.forEach((event) => { %>
            <section class="admin-event-editor" aria-labelledby="event-editor-<%= event.id %>">
              <div class="admin-list-item">
                <p>
                  <strong id="event-editor-<%= event.id %>"><%= event.publicTitle %></strong>
                  <span><%= event.eventDate || "날짜 미정" %> · <%= event.status %> · <%= event.isFeatured ? "대표" : "보관" %></span>
                </p>
                <% if (!event.isFeatured) { %>
                  <form method="post" action="/admin/events/<%= event.id %>/feature">
                    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                    <button class="button button-disabled" type="submit">대표 지정</button>
                  </form>
                <% } %>
              </div>

              <form method="post" action="/admin/events/<%= event.id %>" class="admin-form">
                <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

                <label>
                  공개 제목
                  <input name="publicTitle" value="<%= event.publicTitle %>" required maxlength="80">
                </label>
                <label>
                  기수 라벨
                  <input name="generationLabel" value="<%= event.generationLabel %>" required maxlength="40">
                </label>
                <label>
                  날짜
                  <input name="eventDate" value="<%= event.eventDate %>" required maxlength="40">
                </label>
                <label>
                  지역
                  <input name="region" value="<%= event.region %>" required maxlength="40">
                </label>
                <label>
                  장소 안내
                  <input name="venueNote" value="<%= event.venueNote %>" required maxlength="120">
                </label>
                <label>
                  정원
                  <input name="capacityNote" value="<%= event.capacityNote %>" required maxlength="60">
                </label>
                <label class="admin-form-wide">
                  신청 조건
                  <input name="applicationConditions" value="<%= event.applicationConditions %>" required maxlength="120">
                </label>
                <label>
                  모집 상태
                  <select name="status">
                    <% ["open", "closing-soon", "closed", "scheduled", "hidden"].forEach((status) => { %>
                      <option value="<%= status %>" <%= event.status === status ? "selected" : "" %>><%= status %></option>
                    <% }) %>
                  </select>
                </label>
                <label>
                  구글폼 링크
                  <input name="googleFormUrl" value="<%= event.googleFormUrl %>" required inputmode="url">
                </label>
                <label class="admin-form-wide">
                  시간 슬롯
                  <textarea name="timeSlotsText" required><%= event.timeSlotsText %></textarea>
                </label>
                <label class="admin-form-wide">
                  참가비
                  <textarea name="priceRowsText" required><%= event.priceRowsText %></textarea>
                </label>

                <button class="button button-primary admin-form-wide" type="submit">행사 저장</button>
              </form>
            </section>
          <% }) %>
        </div>
      <% } else { %>
        <p class="admin-empty">등록된 일정이 없습니다.</p>
      <% } %>
    </article>

    <article class="admin-card">
      <h2>새 일정 추가</h2>
      <form method="post" action="/admin/events" class="admin-form compact-form" aria-label="새 일정 추가">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
        <label>
          공개 제목
          <input name="publicTitle" placeholder="새 일정 제목" required maxlength="80">
        </label>
        <label>
          기수 라벨
          <input name="generationLabel" placeholder="기수 라벨" required maxlength="40">
        </label>
        <label>
          날짜
          <input name="eventDate" placeholder="날짜" required maxlength="40">
        </label>
        <label>
          지역
          <input name="region" value="서울 강남권" required maxlength="40">
        </label>
        <label>
          장소 안내
          <input name="venueNote" value="참여 확정자 개별 안내" required maxlength="120">
        </label>
        <label>
          정원
          <input name="capacityNote" value="최대 10:10" required maxlength="60">
        </label>
        <label class="admin-form-wide">
          신청 조건
          <input name="applicationConditions" placeholder="신청 조건" required maxlength="120">
        </label>
        <label>
          모집 상태
          <select name="status">
            <option value="scheduled">scheduled</option>
            <option value="open">open</option>
            <option value="closing-soon">closing-soon</option>
            <option value="closed">closed</option>
            <option value="hidden">hidden</option>
          </select>
        </label>
        <label>
          구글폼 링크
          <input name="googleFormUrl" value="https://forms.gle/demo" required inputmode="url">
        </label>
        <label class="admin-form-wide">
          시간 슬롯
          <textarea name="timeSlotsText" required>1회차|16:00|18:00</textarea>
        </label>
        <label class="admin-form-wide">
          참가비
          <textarea name="priceRowsText" required>기본|35,000원|</textarea>
        </label>
        <button class="button button-primary admin-form-wide" type="submit">새 일정 추가</button>
      </form>
    </article>
  </section>

  <section class="admin-card content-editor" aria-labelledby="content-editor-title">
    <h2 id="content-editor-title">홈 콘텐츠 / 검색 미리보기 / 법무 정보</h2>
    <form method="post" action="/admin/content" class="admin-form">
      <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

      <label>
        상단 로고 텍스트
        <input name="headerTitle" value="<%= adminContent.headerTitle %>" required maxlength="40">
      </label>
      <label>
        히어로 라벨
        <input name="heroEyebrow" value="<%= adminContent.heroEyebrow %>" required maxlength="80">
      </label>
      <label>
        히어로 제목
        <input name="heroHeadline" value="<%= adminContent.heroHeadline %>" required maxlength="140">
      </label>
      <label class="admin-form-wide">
        히어로 설명
        <textarea name="heroSubheadline" required maxlength="500"><%= adminContent.heroSubheadline %></textarea>
      </label>
      <label>
        히어로 배지
        <textarea name="heroBadgesText" required maxlength="500"><%= adminContent.heroBadgesText %></textarea>
      </label>
      <label>
        다음 기수 CTA 라벨
        <input name="nextCtaLabel" value="<%= adminContent.nextCtaLabel %>" required maxlength="40">
      </label>
      <label>
        참여자 예시
        <textarea name="participantsText" required maxlength="500"><%= adminContent.participantsText %></textarea>
      </label>
      <label class="admin-form-wide">
        지원현황 노션 URL
        <input name="applicationStatusUrl" value="<%= adminContent.applicationStatusUrl %>" required inputmode="url">
      </label>
      <label>
        지원현황 기준 문구
        <input name="applicationStatusUpdatedLabel" value="<%= adminContent.applicationStatusUpdatedLabel %>" required maxlength="80">
      </label>
      <label>
        남자 지원 요약
        <input name="applicationStatusMaleSummary" value="<%= adminContent.applicationStatusMaleSummary %>" required maxlength="40">
      </label>
      <label>
        여자 지원 요약
        <input name="applicationStatusFemaleSummary" value="<%= adminContent.applicationStatusFemaleSummary %>" required maxlength="40">
      </label>
      <label>
        남자 연령대별 현황
        <textarea name="applicationStatusMaleRowsText" required maxlength="1000"><%= adminContent.applicationStatusMaleRowsText %></textarea>
      </label>
      <label>
        여자 연령대별 현황
        <textarea name="applicationStatusFemaleRowsText" required maxlength="1000"><%= adminContent.applicationStatusFemaleRowsText %></textarea>
      </label>
      <label class="admin-form-wide">
        지원현황 안내 문구
        <textarea name="applicationStatusNotesText" required maxlength="800"><%= adminContent.applicationStatusNotesText %></textarea>
      </label>
      <label>
        인스타그램 URL
        <input name="instagramUrl" value="<%= adminContent.instagramUrl %>" required inputmode="url">
      </label>
      <label>
        인스타그램 핸들
        <input name="instagramHandle" value="<%= adminContent.instagramHandle %>" required maxlength="60">
      </label>
      <label class="admin-form-wide">
        인스타그램 릴스
        <textarea name="instagramReelsText" maxlength="1200"><%= adminContent.instagramReelsText %></textarea>
      </label>
      <label class="admin-form-wide">
        검색 제목
        <input name="seoTitle" value="<%= adminContent.seoTitle %>" required maxlength="120">
      </label>
      <label class="admin-form-wide">
        검색 설명
        <textarea name="seoDescription" required maxlength="500"><%= adminContent.seoDescription %></textarea>
      </label>
      <label class="admin-form-wide">
        검색/공유 미리보기 이미지 URL
        <input name="seoImageUrl" value="<%= adminContent.seoImageUrl %>" required maxlength="240">
      </label>
      <label>
        검색 이미지 대체 문구
        <input name="seoImageAlt" value="<%= adminContent.seoImageAlt %>" required maxlength="120">
      </label>
      <label>
        네이버 사이트 인증 코드
        <input name="naverVerification" value="<%= adminContent.naverVerification %>" maxlength="120">
      </label>
      <label class="admin-form-wide">
        FAQ
        <textarea name="faqText" required maxlength="3000"><%= adminContent.faqText %></textarea>
      </label>
      <label>
        푸터 제목
        <input name="footerTitle" value="<%= adminContent.footerTitle %>" required maxlength="80">
      </label>
      <label class="admin-form-wide">
        푸터 설명
        <input name="footerDescription" value="<%= adminContent.footerDescription %>" required maxlength="160">
      </label>
      <label>
        대표자
        <input name="representative" value="<%= adminContent.representative %>" required maxlength="80">
      </label>
      <label>
        문의 채널
        <input name="contact" value="<%= adminContent.contact %>" required maxlength="120">
      </label>
      <label class="admin-form-wide">
        카카오톡 오픈채팅 URL
        <input name="directContactUrl" value="<%= adminContent.directContactUrl %>" maxlength="240" inputmode="url" placeholder="https://open.kakao.com/o/...">
      </label>
      <label>
        직접 문의 버튼 라벨
        <input name="directContactLabel" value="<%= adminContent.directContactLabel %>" required maxlength="60">
      </label>
      <label>
        도메인
        <input name="domain" value="<%= adminContent.domain %>" required maxlength="80">
      </label>

      <button class="button button-primary admin-form-wide" type="submit">콘텐츠 저장</button>
    </form>
  </section>

  <section class="admin-card traffic-log" aria-labelledby="traffic-log-title">
    <div class="traffic-log-header">
      <div>
        <p class="eyebrow">Traffic Log</p>
        <h2 id="traffic-log-title">시간대별 홈페이지 접속</h2>
        <p>최근 <%= trafficLog.hours %>시간 기준입니다. 익명 브라우저 쿠키로 시간대별 고유 방문자와 페이지뷰만 집계합니다.</p>
      </div>
      <div class="traffic-summary">
        <span><strong><%= trafficLog.totalUniqueVisitors %></strong><small>시간대별 방문자 합계</small></span>
        <span><strong><%= trafficLog.totalPageViews %></strong><small>페이지뷰 합계</small></span>
        <span><strong><%= trafficLog.busiestHour?.uniqueVisitors || 0 %></strong><small>최고 시간대 방문자</small></span>
        <span><strong><%= trafficLog.applyClickCount %></strong><small>신청 버튼 클릭</small></span>
        <span><strong><%= trafficLog.menuClickCount %></strong><small>메뉴 클릭</small></span>
      </div>
    </div>

    <div class="traffic-insights" aria-label="클릭과 유입 경로 요약">
      <section>
        <h3>신청하기 버튼 클릭</h3>
        <% if (trafficLog.applyClickRows.length) { %>
          <ul>
            <% trafficLog.applyClickRows.forEach((row) => { %>
              <li><span><%= row.label || "신청 버튼" %></span><strong><%= row.count %>회</strong><small><%= row.uniqueVisitors %>명</small></li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>아직 기록된 클릭이 없습니다.</p>
        <% } %>
      </section>
      <section>
        <h3>메뉴 클릭 순위</h3>
        <% if (trafficLog.menuClickRows.length) { %>
          <ul>
            <% trafficLog.menuClickRows.forEach((row) => { %>
              <li><span><%= row.label || "메뉴" %></span><strong><%= row.count %>회</strong><small><%= row.uniqueVisitors %>명</small></li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>아직 기록된 메뉴 클릭이 없습니다.</p>
        <% } %>
      </section>
      <section>
        <h3>유입 경로</h3>
        <% if (trafficLog.sourceRows.length) { %>
          <ul>
            <% trafficLog.sourceRows.forEach((row) => { %>
              <li><span><%= row.source || "direct" %></span><strong><%= row.uniqueVisitors %>명</strong><small><%= row.count %>회</small></li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>아직 기록된 유입 경로가 없습니다.</p>
        <% } %>
      </section>
      <section>
        <h3>유입 검색어 / UTM</h3>
        <% if (trafficLog.searchTermRows.length) { %>
          <ul>
            <% trafficLog.searchTermRows.forEach((row) => { %>
              <li><span><%= row.searchTerm %></span><strong><%= row.count %>회</strong><small><%= row.uniqueVisitors %>명</small></li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>검색엔진이 검색어를 전달하지 않으면 비어 있을 수 있습니다.</p>
        <% } %>
      </section>
    </div>

    <div class="traffic-chart" aria-label="최근 시간대별 방문자 막대그래프">
      <% trafficLog.rows.forEach((row) => { %>
        <div class="traffic-bar-column" title="<%= row.fullLabel %> · 방문자 <%= row.uniqueVisitors %>명 · 페이지뷰 <%= row.pageViews %>">
          <span class="traffic-bar" style="height: <%= row.barPercent %>%"></span>
          <small><%= row.hourLabel %></small>
        </div>
      <% }) %>
    </div>

    <div class="traffic-table-wrap">
      <table class="traffic-table">
        <thead>
          <tr>
            <th>날짜</th>
            <th>요일</th>
            <th>시간</th>
            <th>고유 방문자</th>
            <th>페이지뷰</th>
          </tr>
        </thead>
        <tbody>
          <% trafficLog.rows.slice().reverse().forEach((row) => { %>
            <tr>
              <td><%= row.dateLabel %></td>
              <td><%= row.weekdayLabel %></td>
              <td><%= row.hourLabel %></td>
              <td><%= row.uniqueVisitors %></td>
              <td><%= row.pageViews %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
